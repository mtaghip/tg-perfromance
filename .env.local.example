# AutoTrader Connect API — required for live stock
# Contact your AutoTrader account manager or partner.support@autotrader.co.uk
AUTOTRADER_API_KEY=your_api_key_here
AUTOTRADER_API_SECRET=your_api_secret_here
AUTOTRADER_ADVERTISER_ID=your_dealer_id_here

# Google Tag Manager — add your container ID to enable GTM on all pages
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Email (optional) — uncomment nodemailer block in pages/api/enquiry.js to activate
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=your@gmail.com
# EMAIL_SMTP_PASS=your_app_password
